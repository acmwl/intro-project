{
  "title": "Audio Measurements",
  "uid": "audio-measurements",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "RMS Level (dBFS)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "dB",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "calcs": ["last", "min", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "format": "time_series",
          "rawSql": "SELECT recorded_at AS time, rms_db AS \"RMS (dBFS)\" FROM measurements WHERE $__timeFilter(recorded_at) ORDER BY recorded_at"
        }
      ]
    },
    {
      "id": 2,
      "title": "Peak Frequency (Hz)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "hertz",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "calcs": ["last", "min", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "format": "time_series",
          "rawSql": "SELECT recorded_at AS time, peak_frequency_hz AS \"Peak Frequency (Hz)\" FROM measurements WHERE $__timeFilter(recorded_at) ORDER BY recorded_at"
        }
      ]
    },
    {
      "id": 3,
      "title": "Baseline Delta (dB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "dB",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 6 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "calcs": ["last"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "format": "time_series",
          "rawSql": "SELECT recorded_at AS time, baseline_delta_db AS \"Delta (dB)\" FROM measurements WHERE $__timeFilter(recorded_at) ORDER BY recorded_at"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pass Rate",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green",  "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "format": "table",
          "rawSql": "SELECT ROUND(SUM(CASE WHEN passed_baseline THEN 1 ELSE 0 END)::numeric / NULLIF(COUNT(*),0), 2) AS \"Pass Rate\" FROM measurements WHERE $__timeFilter(recorded_at)"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Recordings",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Total Recordings\" FROM measurements WHERE $__timeFilter(recorded_at)"
        }
      ]
    },
    {
      "id": 6,
      "title": "Recent Recordings",
      "type": "table",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rms_db" },
            "properties": [{ "id": "unit", "value": "dB" }]
          },
          {
            "matcher": { "id": "byName", "options": "peak_frequency_hz" },
            "properties": [{ "id": "unit", "value": "hertz" }]
          },
          {
            "matcher": { "id": "byName", "options": "baseline_delta_db" },
            "properties": [{ "id": "unit", "value": "dB" }]
          }
        ]
      },
      "options": { "cellHeight": "sm", "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "format": "table",
          "rawSql": "SELECT recorded_at, filename, rms_db, peak_frequency_hz, baseline_delta_db, passed_baseline FROM measurements ORDER BY recorded_at DESC LIMIT 20"
        }
      ]
    }
  ]
}
