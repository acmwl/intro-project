          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \r\nCONCAT (\r\n  FLOOR (rms_db / 5.0) * 5.0,\r\n   ' to ',\r\n  FLOOR (rms_db / 5.0) * 5.0,\r\n  ' dBFS '\r\n) AS range_rms,\r\nCOUNT (*) AS \"Recordings\"\r\nFROM measurements\r\nWHERE rms_db IS NOT NULL\r\nAND $__timeFilter(recorded_at) \r\nGROUP BY FLOOR (rms_db / 5.0) * 5.0\r\nORDER BY FLOOR (rms_db / 5.0) * 5.0",
          "refId": "A",
          "sql": {
            "columns": [
